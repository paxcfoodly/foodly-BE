  @@index([incoming_id])
  @@index([item_cd])
  @@map("tb_incoming_dtl")
}

// ════════════════════════════════════════════════════════════════════
//  SYSTEM TABLES (14) — proposal.md section 5-3
// ════════════════════════════════════════════════════════════════════

// ────────────────────────────────────────
// S01: TB_USER — 사용자
// ────────────────────────────────────────
model TbUser {
  user_id    Int     @id @default(autoincrement())
  login_id   String  @unique @db.VarChar(50)
  password   String  @db.VarChar(200) // bcrypt hashed
  user_nm    String  @db.VarChar(50)
  role_cd    String? @db.VarChar(20)
  company_cd String? @db.VarChar(20)
  status     String  @default("ACTIVE") @db.VarChar(20) // ACTIVE, INACTIVE, LOCKED

  create_by String?  @db.VarChar(50)
  create_dt DateTime @default(now())
  update_by String?  @db.VarChar(50)
  update_dt DateTime @updatedAt

  // Relations
  role          TbRole?          @relation(fields: [role_cd], references: [role_cd])
  company       TbCompany?       @relation(fields: [company_cd], references: [company_cd])
  notifications TbNotification[]
  audit_logs    TbAuditLog[]

  @@index([role_cd])
  @@index([company_cd])
  @@map("tb_user")
}

// ────────────────────────────────────────
// S02: TB_ROLE — 역할
// ────────────────────────────────────────
model TbRole {
  role_cd   String  @id @db.VarChar(20)
  role_nm   String  @db.VarChar(50)
  role_desc String? @db.VarChar(200)
  use_yn    String  @default("Y") @db.Char(1)

  create_by String?  @db.VarChar(50)
  create_dt DateTime @default(now())
  update_by String?  @db.VarChar(50)
  update_dt DateTime @updatedAt

  // Relations
  users      TbUser[]
  role_menus TbRoleMenu[]
  noti_rules TbNotiRule[]

  @@map("tb_role")
}

// ────────────────────────────────────────
// S03: TB_MENU — 메뉴
// ────────────────────────────────────────
model TbMenu {
  menu_id        Int     @id @default(autoincrement())
  parent_menu_id Int?
  menu_nm        String  @db.VarChar(100)
  menu_url       String? @db.VarChar(200)
  sort_order     Int     @default(0)
  depth          Int     @default(1)
  use_yn         String  @default("Y") @db.Char(1)

  create_by String?  @db.VarChar(50)
  create_dt DateTime @default(now())
  update_by String?  @db.VarChar(50)
  update_dt DateTime @updatedAt

  // Relations
  parent     TbMenu?      @relation("MenuHierarchy", fields: [parent_menu_id], references: [menu_id])
  children   TbMenu[]     @relation("MenuHierarchy")
  role_menus TbRoleMenu[]

  @@index([parent_menu_id])
  @@map("tb_menu")
}

// ────────────────────────────────────────
// S04: TB_ROLE_MENU — 역할-메뉴 권한 (복합PK)
// ────────────────────────────────────────
model TbRoleMenu {
  role_cd    String  @db.VarChar(20)
  menu_id    Int
  can_create String  @default("N") @db.Char(1)
  can_read   String  @default("Y") @db.Char(1)
  can_update String  @default("N") @db.Char(1)
  can_delete String  @default("N") @db.Char(1)
  can_print  String  @default("N") @db.Char(1)

  create_by String?  @db.VarChar(50)
  create_dt DateTime @default(now())
  update_by String?  @db.VarChar(50)
  update_dt DateTime @updatedAt

  // Relations
  role TbRole @relation(fields: [role_cd], references: [role_cd])
  menu TbMenu @relation(fields: [menu_id], references: [menu_id])

  @@id([role_cd, menu_id])
  @@map("tb_role_menu")
}

// ────────────────────────────────────────
// S05: TB_COMMON_CODE_GRP — 공통코드 그룹
// ────────────────────────────────────────
model TbCommonCodeGrp {
  group_cd String @id @db.VarChar(30)
  group_nm String @db.VarChar(100)
  use_yn   String @default("Y") @db.Char(1)

  create_by String?  @db.VarChar(50)
  create_dt DateTime @default(now())
  update_by String?  @db.VarChar(50)
  update_dt DateTime @updatedAt

  // Relations
  codes TbCommonCode[]

  @@map("tb_common_code_grp")
}

// ────────────────────────────────────────
// S06: TB_COMMON_CODE — 공통코드 상세 (복합PK)
// ────────────────────────────────────────
model TbCommonCode {
  group_cd   String @db.VarChar(30)
  code       String @db.VarChar(30)
  code_nm    String @db.VarChar(100)
  sort_order Int    @default(0)
  use_yn     String @default("Y") @db.Char(1)

  create_by String?  @db.VarChar(50)
  create_dt DateTime @default(now())
  update_by String?  @db.VarChar(50)
  update_dt DateTime @updatedAt

  // Relations
  group TbCommonCodeGrp @relation(fields: [group_cd], references: [group_cd])

  @@id([group_cd, code])
  @@map("tb_common_code")
}

// ────────────────────────────────────────
// S07: TB_NUMBERING — 채번 규칙
// ────────────────────────────────────────
model TbNumbering {
  num_type    String @id @db.VarChar(30)
  prefix      String @db.VarChar(10)
  date_format String @default("YYMMDD") @db.VarChar(10)
  seq_length  Int    @default(4)
  last_seq    Int    @default(0)

  create_by String?  @db.VarChar(50)
  create_dt DateTime @default(now())
  update_by String?  @db.VarChar(50)
  update_dt DateTime @updatedAt

  @@map("tb_numbering")
}

// ────────────────────────────────────────
// S08: TB_FILE — 파일 첨부
// ────────────────────────────────────────
model TbFile {
  file_id     Int    @id @default(autoincrement())
  original_nm String @db.VarChar(200)
  stored_nm   String @db.VarChar(200)
  file_path   String @db.VarChar(500)
  file_size   Int?
  file_ext    String? @db.VarChar(10)
  ref_table   String? @db.VarChar(50) // 참조 테이블명
  ref_id      String? @db.VarChar(50) // 참조 레코드 ID

  create_by String?  @db.VarChar(50)
  create_dt DateTime @default(now())

  @@index([ref_table, ref_id])
  @@map("tb_file")
}

// ────────────────────────────────────────
// S09: TB_AUDIT_LOG — 감사 로그
// ────────────────────────────────────────
model TbAuditLog {
  log_id       Int     @id @default(autoincrement())
  user_id      Int?
  action       String  @db.VarChar(20) // CREATE, UPDATE, DELETE, LOGIN, LOGOUT
  target_table String? @db.VarChar(50)
  record_id    String? @db.VarChar(50)
  before_data  Json?   // 변경 전 데이터
  after_data   Json?   // 변경 후 데이터
  ip_address   String? @db.VarChar(50)

  create_dt DateTime @default(now())

  // Relations
  user TbUser? @relation(fields: [user_id], references: [user_id])

  @@index([user_id])
  @@index([target_table])
  @@index([create_dt])
  @@map("tb_audit_log")
}

// ────────────────────────────────────────
// S10: TB_NOTIFICATION — 알림
// ────────────────────────────────────────
model TbNotification {
  noti_id        Int     @id @default(autoincrement())
  noti_type      String? @db.VarChar(20)
  noti_title     String  @db.VarChar(200)
  noti_content   String? @db.Text
  target_user_id Int?
  channel        String? @db.VarChar(20) // WEB, EMAIL, SMS
  send_status    String  @default("PENDING") @db.VarChar(20) // PENDING, SENT, FAILED
  read_yn        String  @default("N") @db.Char(1)

  create_dt DateTime @default(now())

  // Relations
  target_user TbUser? @relation(fields: [target_user_id], references: [user_id])

  @@index([target_user_id])
  @@index([read_yn])
  @@map("tb_notification")
}

// ────────────────────────────────────────
// S11: TB_NOTI_RULE — 알림 규칙
// ────────────────────────────────────────
model TbNotiRule {
  rule_id        Int     @id @default(autoincrement())
  event_type     String  @db.VarChar(50) // WO_CREATED, DEFECT_FOUND, etc.
  target_role_cd String? @db.VarChar(20)
  channel        String? @db.VarChar(20)
  template_id    String? @db.VarChar(50)
  use_yn         String  @default("Y") @db.Char(1)

  create_by String?  @db.VarChar(50)
  create_dt DateTime @default(now())
  update_by String?  @db.VarChar(50)
  update_dt DateTime @updatedAt

  // Relations
  target_role TbRole? @relation(fields: [target_role_cd], references: [role_cd])

  @@index([event_type])
  @@map("tb_noti_rule")
}

// ────────────────────────────────────────
// S12: TB_BATCH_LOG — 배치 실행 이력
// ────────────────────────────────────────
model TbBatchLog {
  batch_log_id Int       @id @default(autoincrement())
  batch_nm     String    @db.VarChar(100)
  start_dt     DateTime?
  end_dt       DateTime?
  status       String    @default("RUNNING") @db.VarChar(20) // RUNNING, SUCCESS, FAILED
  result_msg   String?   @db.Text

  create_dt DateTime @default(now())

  @@index([batch_nm])
  @@index([start_dt])
  @@map("tb_batch_log")
}

// ────────────────────────────────────────
// S13: TB_NOTICE — 공지사항
// ────────────────────────────────────────
model TbNotice {
  notice_id Int     @id @default(autoincrement())
  title     String  @db.VarChar(200)
  content   String? @db.Text
  is_popup  String  @default("N") @db.Char(1)

  create_by String?  @db.VarChar(50)
  create_dt DateTime @default(now())
  update_by String?  @db.VarChar(50)
  update_dt DateTime @updatedAt

  @@map("tb_notice")
}

// ────────────────────────────────────────
// S14: TB_DATA_HISTORY — 데이터 변경이력
// ────────────────────────────────────────
model TbDataHistory {
  history_id    Int     @id @default(autoincrement())
  table_nm      String  @db.VarChar(50)
  record_id     String  @db.VarChar(50)
  column_nm     String  @db.VarChar(50)
  before_value  String? @db.Text
  after_value   String? @db.Text
  change_reason String? @db.VarChar(500)
  change_by     String? @db.VarChar(50)

  change_dt DateTime @default(now())

  @@index([table_nm, record_id])
  @@index([change_dt])
  @@map("tb_data_history")
}
