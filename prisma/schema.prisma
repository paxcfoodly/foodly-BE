  cancel_reason  String? @db.VarChar(500)
  cancel_by      String? @db.VarChar(50)
  cancel_dt      DateTime?
  remark         String? @db.VarChar(500)

  create_by String?  @db.VarChar(50)
  create_dt DateTime @default(now())
  update_by String?  @db.VarChar(50)
  update_dt DateTime @updatedAt

  // Relations
  customer TbCustomer     @relation(fields: [cust_cd], references: [cust_cd])
  details  TbShipmentDtl[]

  @@index([cust_cd])
  @@map("tb_shipment")
}

// ────────────────────────────────────────
// T22: TB_SHIPMENT_DTL — 출하 상세
// ────────────────────────────────────────
model TbShipmentDtl {
  ship_dtl_id Int     @id @default(autoincrement())
