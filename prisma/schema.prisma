  create_by String?  @db.VarChar(50)
  create_dt DateTime @default(now())
  update_by String?  @db.VarChar(50)
  update_dt DateTime @updatedAt

  // Relations
  shipment TbShipment @relation(fields: [ship_id], references: [ship_id])
  item     TbItem     @relation(fields: [item_cd], references: [item_cd])
  lot      TbLot?     @relation(fields: [lot_no], references: [lot_no])

  @@index([ship_id])
  @@index([item_cd])
  @@map("tb_shipment_dtl")
}

// ────────────────────────────────────────
// T23: TB_INCOMING — 입고
// ────────────────────────────────────────
model TbIncoming {
  incoming_id Int    @id @default(autoincrement())
  incoming_no String @unique @db.VarChar(30)
  cust_cd     String @db.VarChar(20)
  status      String @default("PLAN") @db.VarChar(20)

  create_by String?  @db.VarChar(50)
  create_dt DateTime @default(now())
  update_by String?  @db.VarChar(50)
  update_dt DateTime @updatedAt

  // Relations
  customer TbCustomer    @relation(fields: [cust_cd], references: [cust_cd])
  details  TbIncomingDtl[]

  @@index([cust_cd])
  @@map("tb_incoming")
}

// ────────────────────────────────────────
// T24: TB_INCOMING_DTL — 입고 상세
// ────────────────────────────────────────
model TbIncomingDtl {
  incoming_dtl_id Int     @id @default(autoincrement())
  incoming_id     Int
  item_cd         String  @db.VarChar(30)
  lot_no          String? @db.VarChar(50)
  incoming_qty    Decimal @db.Decimal(15, 3)
  inspect_status  String? @db.VarChar(20) // PENDING, PASS, FAIL

  create_by String?  @db.VarChar(50)
  create_dt DateTime @default(now())
  update_by String?  @db.VarChar(50)
  update_dt DateTime @updatedAt

  // Relations
  incoming TbIncoming @relation(fields: [incoming_id], references: [incoming_id])
