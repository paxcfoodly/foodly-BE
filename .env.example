# Server
PORT=4000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/foodly_mes?schema=public
# Direct (non-pooled) URL — required by Prisma migrate when DATABASE_URL
# points at a pgbouncer pool (e.g. Supabase port 6543). For local dev the
# two URLs can be identical.
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/foodly_mes?schema=public
# Optional — only needed when running `prisma migrate dev/diff` against
# a managed DB (Supabase Free) that doesn't permit shadow DB creation.
# Point at a local empty Postgres DB; Prisma uses it transiently to
# validate the next migration without touching production data.
# SHADOW_DATABASE_URL=postgres://localhost:5432/foodly_shadow

# JWT
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_EXPIRES_IN=8h

# CORS
CORS_ORIGIN=http://localhost:3000

# Default password assigned to newly-created users and password resets.
# Change to a strong value in production.
DEFAULT_USER_PASSWORD=foodly1234!
